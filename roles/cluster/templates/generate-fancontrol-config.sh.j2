#!/bin/bash
# ==============================================================================
# Dynamic Fancontrol Configuration Generator
# Generated by Ansible for quiet/passive cooling profiles.
# Resolves dynamic hwmon mapping differences across system reboots.
# ==============================================================================

set -euo pipefail

CORETEMP_HWMON=""
NCT_HWMON=""

# Discover dynamic hwmon IDs
for f in /sys/class/hwmon/hwmon*; do
    if [ -f "$f/name" ]; then
        name=$(cat "$f/name")
        if [ "$name" = "coretemp" ]; then
            CORETEMP_HWMON=$(basename "$f")
        elif [ "$name" = "nct6776" ]; then
            NCT_HWMON=$(basename "$f")
        fi
    fi
done

if [ -z "$CORETEMP_HWMON" ]; then
    echo "Error: Could not find hwmon device for 'coretemp' driver" >&2
    exit 1
fi

if [ -z "$NCT_HWMON" ]; then
    echo "Error: Could not find hwmon device for 'nct6776' (nct6775 driver)" >&2
    exit 1
fi

# Resolve physical device paths relative to /sys/
CORETEMP_PATH=$(readlink -f "/sys/class/hwmon/${CORETEMP_HWMON}/device" | sed 's|^/sys/||')
NCT_PATH=$(readlink -f "/sys/class/hwmon/${NCT_HWMON}/device" | sed 's|^/sys/||')

echo "Found coretemp at ${CORETEMP_HWMON} (${CORETEMP_PATH})"
echo "Found nct6776 at ${NCT_HWMON} (${NCT_PATH})"

# Write configuration
cat <<EOF > /etc/fancontrol
INTERVAL={{ fancontrol_interval }}
DEVPATH=${CORETEMP_HWMON}=${CORETEMP_PATH} ${NCT_HWMON}=${NCT_PATH}
DEVNAME=${CORETEMP_HWMON}=coretemp ${NCT_HWMON}=nct6776
FCTEMPS=${NCT_HWMON}/pwm2=${CORETEMP_HWMON}/temp1_input ${NCT_HWMON}/pwm1=${CORETEMP_HWMON}/temp1_input
FCFANS=${NCT_HWMON}/pwm2=${NCT_HWMON}/fan2_input ${NCT_HWMON}/pwm1=${NCT_HWMON}/fan1_input
MINTEMP=${NCT_HWMON}/pwm2={{ fancontrol_mintemp_chassis }} ${NCT_HWMON}/pwm1={{ fancontrol_mintemp_cpu }}
MAXTEMP=${NCT_HWMON}/pwm2={{ fancontrol_maxtemp_chassis }} ${NCT_HWMON}/pwm1={{ fancontrol_maxtemp_cpu }}
MINSTART=${NCT_HWMON}/pwm2={{ fancontrol_minstart_chassis }} ${NCT_HWMON}/pwm1={{ fancontrol_minstart_cpu }}
MINSTOP=${NCT_HWMON}/pwm2={{ fancontrol_minstop_chassis }} ${NCT_HWMON}/pwm1={{ fancontrol_minstop_cpu }}
MINPWM=${NCT_HWMON}/pwm2={{ fancontrol_minpwm_chassis }} ${NCT_HWMON}/pwm1={{ fancontrol_minpwm_cpu }}
MAXPWM=${NCT_HWMON}/pwm2={{ fancontrol_maxpwm_chassis }} ${NCT_HWMON}/pwm1={{ fancontrol_maxpwm_cpu }}
EOF

echo "Successfully wrote /etc/fancontrol"
