# ==============================================================================
# Managed by Ansible - PXELINUX Network Boot Configuration
# ==============================================================================

# Boot automatically and immediately without loading VESA menus
default auto
prompt 0
timeout 1

label auto
    kernel debian-installer/amd64/linux
    append auto=true priority=critical vga=788 initrd=debian-installer/amd64/initrd.gz preseed/url=http://{{ pxe_server_ip }}:8080/preseed.cfg --- quiet
